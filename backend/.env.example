# Local development (SQLite file in backend directory)
DATABASE_URL=sqlite+aiosqlite:///./lesly.db
ENVIRONMENT=development
PAPER_TRADING=true
SECRET_KEY=change-me-in-production
ENCRYPTION_KEY=change-me-too
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production on Render + Neon (set in Render dashboard)
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
# ENVIRONMENT=production
# SECRET_KEY=<long-random-string>
# ENCRYPTION_KEY=<different-long-random-string>
