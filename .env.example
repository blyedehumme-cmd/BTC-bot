# Configuración mínima para ejecutar el bot en modo local / DRY_RUN
TELEGRAM_TOKEN=
CHAT_ID=
TELEGRAM_POLLING_ENABLED=false
CB_API_KEY=
CB_API_SECRET=
EXCHANGE=kraken
EXCHANGE_MODE=futures
PRODUCT_ID=BTC-USDC
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
KRAKEN_PAIR=XBTUSD
KRAKEN_FUTURES_SYMBOL=PI_XBTUSD
KRAKEN_BASE_ASSET=XXBT
KRAKEN_QUOTE_ASSET=ZUSD
STRATEGY_PROFILE=btc_swing_v1
OPTIMIZED_SYMBOLS=BTC,ETH
WATCHLIST=BTC,ETH
SYMBOL_SIGNAL_SIDES=BTC:LONG,SHORT;ETH:SHORT
TRAILING_ACTIVATION_ATR=1.0
SYMBOL_HMM_REGIMES=ETH:4
DRY_RUN=true
USE_AI_ASSIST=false
# Dejalo vacio si no quieres enviar datos al backend.
BACKEND_API_URL=http://localhost:8000/api

# Opcionales
MIN_CONFIDENCE=0.70
MIN_MINUTES_BETWEEN_TRADES=240
MAX_TRADES_PER_DAY=3
MAX_OPEN_POSITIONS=2
MAX_RISK_PER_TRADE=0.03
MAX_DAILY_LOSS=0.03
ANALYZE_EVERY_SECONDS=300
DRY_RUN_BALANCE=5000
STATE_FILE=bot_state.json
RUN_ONCE=false
ATR_STOP_MULTIPLIER=1.5
ATR_TAKE_PROFIT_MULTIPLIER=3.0
ATR_TRAILING_MULTIPLIER=2.0
MAX_POSITION_BALANCE_PCT=1.0
MAX_LEVERAGE=3
MIN_ORDER_USD=10
ADX_THRESHOLD=24
VOLUME_HEALTH_MIN=0.60
REQUIRE_MTF_MACD_CONFIRM=true

# Seguridad: spot no abre shorts reales. Mantener false salvo que entiendas
# que una senal SHORT real ejecutaria una venta de BTC disponible.
ALLOW_REAL_SPOT_SHORT=false

# OpenAI opcional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
